<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Overlay strings — Shopno Store branding. The decoded APKPure
      strings.xml is patched by apply_overlay.py via the strings.txt
      swap table; this file provides the canonical copy of the new
      strings so they live in the resource table for runtime lookups
      (Shopno-themed dialogs, About screens, etc.).
    -->
    <string name="app_name">Shopno Store</string>
    <string name="app_tagline">Apps for everything you do with Shopnoltd.</string>
    <string name="app_company">Shopnoltd Ltd</string>
    <string name="app_support_email">support@shopnoltd.dpdns.org</string>
    <string name="app_website">https://shopnoltd.dpdns.org</string>
    <string name="app_privacy_url">https://shopnoltd.dpdns.org/privacy</string>
    <string name="app_terms_url">https://shopnoltd.dpdns.org/terms</string>

    <!-- Endpoints — used at runtime for the SSO / "Open in browser" feature -->
    <string name="endpoints_asset">endhosts.json</string>
    <string name="endpoints_base_url">https://shopnoltd.dpdns.org</string>

    <!-- UI strings that APKPure showed with the APKPure brand; we override
         them with Shopno-flavoured copy. Keep the original `name=`
         attributes stable so APKPure's smali that looks up
         R.string.<name> still resolves. -->
    <string name="apkpure_app_name">Shopno Store</string>
    <string name="apkpure_app_introduction">Apps for everything you do with Shopnoltd.</string>
    <string name="apkpure_app_company">Shopnoltd Ltd</string>
