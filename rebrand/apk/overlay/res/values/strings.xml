    <string name="apkpure_app_privacy">https://shopnoltd.dpdns.org/privacy</string>
    <string name="apkpure_app_terms">https://shopnoltd.dpdns.org/terms</string>

    <!-- Catalog of in-app services, mirroring common/endpoints.yaml.
