<?xml version="1.0" encoding="utf-8"?>
<!--
  Required by targetSdkVersion >= 31. Tells Android which user data
  to back up / transfer between devices. We disable backup for the
  rebrand — the rebranded app should not carry APKPure's analytics IDs
  or user history across reinstalls.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
