# Copy to .env for local testing, or put these into a Kubernetes Secret for the cluster.
# Any gateway left blank automatically runs in DEMO MODE (clearly labeled is_demo:true in API responses) —
# nothing is faked as "live" silently.

DATABASE_URL=postgresql://user:password@postgres:5432/billing
BASE_CALLBACK_URL=https://billing.shopnoltd.dpdns.org

# --- Stripe (global cards) ---
# Get from https://dashboard.stripe.com/apikeys and https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- PayPal (global) ---
# Get from https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# --- Razorpay (India / INR) ---
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- SSLCommerz (Bangladesh) ---
# Get from https://developer.sslcommerz.com/registration/ (sandbox is free/instant)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=true

# --- bKash (Bangladesh) ---
# Merchant onboarding: https://developer.bka.sh/
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_SANDBOX=true

# --- Nagad (Bangladesh) ---
# Merchant onboarding + RSA keypair exchange required: https://nagad.com.bd (merchant service)
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=
NAGAD_PG_PUBLIC_KEY=
NAGAD_SANDBOX=true

# --- Crypto / Bitcoin (via NOWPayments, non-custodial) ---
# Get from https://nowpayments.io (instant signup, has a sandbox)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=true

# --- Payoneer (PAYOUTS to sellers/affiliates only, not customer checkout) ---
# Get from https://payoneer.com developer/partner onboarding
PAYONEER_PROGRAM_ID=
PAYONEER_API_USERNAME=
PAYONEER_API_PASSWORD=
PAYONEER_SANDBOX=true

# --- Live exchange rates ---
# Get a free key from https://openexchangerates.org/signup/free
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_CACHE_SECONDS=3600
