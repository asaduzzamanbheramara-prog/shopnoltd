{
  "appId": "org.shopnoltd.app",
  "productName": "Shopnoltd",
  "directories": { "output": "release/web-portal" },
  "files": ["src/**/*", "package.json"],
  "icon": "build/icon.png",
  "win": { "target": ["nsis"], "icon": "build/icon.png" },
  "mac": { "target": ["dmg"], "icon": "build/icon.png", "category": "public.app-category.business" },
  "linux": { "target": ["AppImage", "deb"], "icon": "build/icon.png", "category": "Network" },
  "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
}
