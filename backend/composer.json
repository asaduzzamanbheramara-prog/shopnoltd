{
  "name": "shopnoltd/backend",
  "description": "ShopNoLtd Laravel backend",
  "type": "project",
  "require": {
    "php": "^8.1 || ^8.2",
    "laravel/framework": "^10.0",
    "guzzlehttp/guzzle": "^7.0.1",
    "laravel/tinker": "^2.8"
  },
  "require-dev": {
    "fakerphp/faker": "^1.9.1",
    "phpunit/phpunit": "^9.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}
